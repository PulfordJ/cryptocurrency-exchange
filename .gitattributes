# Normalise line endings: LF everywhere by default.
* text=auto eol=lf

# Shell scripts and the Gradle wrapper must stay LF.
*.sh    text eol=lf
gradlew text eol=lf

# Windows scripts must stay CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf
gradlew.bat text eol=crlf

# Binary assets.
*.jar binary
